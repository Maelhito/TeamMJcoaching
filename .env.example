# Auth.js — génère avec : openssl rand -base64 32
AUTH_SECRET=

# URL de déploiement (ex: https://ton-app.vercel.app)
NEXTAUTH_URL=

# Upstash Redis — depuis Vercel Dashboard > Storage > Create Database (Redis)
# https://vercel.com/marketplace?category=storage&search=upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob — depuis Vercel Dashboard > Storage > Create Store (Blob)
BLOB_READ_WRITE_TOKEN=
